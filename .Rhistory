rf_demo_pred_20 <- predict(rf_demo_20, test_demo_20)
# Confusion matrices
cat(" CONFUSION MATRICES (2020s) \n\n")
print_cm_short <- function(label, pred, actual) {
cm <- confusionMatrix(pred, actual, positive = "Republican")
cat(label, "\n")
print(cm$table)
cat("Accuracy:", round(cm$overall["Accuracy"], 4),
"| 95% CI: (", round(cm$overall["AccuracyLower"], 4),
",", round(cm$overall["AccuracyUpper"], 4), ")\n")
cat("No Information Rate:", round(cm$overall["AccuracyNull"], 4),
"| P-Value [Acc > NIR]:", format.pval(cm$overall["AccuracyPValue"]), "\n\n")
}
print_cm_short("Attitudes: Logistic Regression", log_att_pred_80, test_att_80$party)
print_cm_short("Attitudes: Random Forest", rf_att_pred_80, test_att_80$party)
print_cm_short("Demographics: Logistic Regression", log_demo_pred_80, test_demo_80$party)
print_cm_short("Demographics: Random Forest", rf_demo_pred_80, test_demo_80$party)
