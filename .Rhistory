library(readxl)
library(dplyr)
library(tidyr)
library(scales)
library(stringr)
library(ggplot2)
library(gridExtra)
library(psych)
library(knitr)
library(randomForest)
library(mice)
# Check number of trees — demographics RF
plot(rf_model, main = "RF Error by Number of Trees (Demographics)")
# Check number of trees — attitudes RF
plot(rf_model, main = "RF Error by Number of Trees (Attitudes)")
data_model <- data_model %>%
mutate(
decade = case_when(
year < 1960  ~ "1950s",
year < 1970  ~ "1960s",
year < 1980  ~ "1970s",
year < 1990  ~ "1980s",
year < 2000  ~ "1990s",
year < 2010  ~ "2000s",
year < 2020  ~ "2010s",
year >= 2020 ~ "2020s"
),
# Factor labels for demographics
gender = factor(gender, levels = c(1, 2), labels = c("Male", "Female")),
race = factor(race, levels = c(1, 2, 3, 4, 5, 6),
labels = c("White", "Black", "Asian/PI",
"Native American", "Hispanic", "Other")),
education = factor(education, levels = c(1, 2, 3, 4),
labels = c("< High School", "High School",
"Some College", "College+")),
region = factor(region, levels = c(1, 2, 3, 4),
labels = c("Northeast", "Midwest", "South", "West")),
religion = factor(religion, levels = c(1, 2, 3, 4),
labels = c("Protestant", "Catholic", "Jewish", "Other/None"))
)
rmarkdown::render("ANES_Data Polarization.rmd", output_format = "html_document")
list.files()
rmarkdown::render("ANES_Data-Polarization.rmd", output_format = "html_document")
rmarkdown::render("ANES_Data_Polarization.rmd", output_format = "html_document")
# Check missingness per decade for our 17 stable attitudes
decades_from_80s <- c("1980s", "1990s", "2000s", "2010s", "2020s")
miss_by_decade <- data_model %>%
filter(decade %in% decades_from_80s) %>%
group_by(decade) %>%
summarise(across(all_of(stable_attitudes_80s),
~round(mean(!is.na(.)) * 100, 0))) %>%
pivot_longer(-decade, names_to = "variable", values_to = "pct_available") %>%
pivot_wider(names_from = decade, values_from = pct_available)
print(miss_by_decade, n = 20)
stable_40 <- stable_attitudes_80s[sapply(stable_attitudes_80s, function(v) {
all(sapply(decades_from_80s, function(dec) {
subset <- data_model %>% filter(decade == dec)
mean(!is.na(subset[[v]])) >= 0.40
}))
})]
cat("Attitudes with >=40% in every decade:\n")
print(stable_40)
cat("\nCount:", length(stable_40))
