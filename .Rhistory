# LogReg demographics
log_demo_80      <- glm(party ~ age + gender + race + education + region + income +
religion + church + marital + work_status + religion_important,
data = train_demo_80, family = binomial)
log_demo_prob_80 <- predict(log_demo_80, test_demo_80, type = "response")
log_demo_pred_80 <- factor(ifelse(log_demo_prob_80 > 0.5, "Republican", "Democrat"),
levels = levels(test_demo_80$party))
# RF demographics
rf_demo_80      <- randomForest(party ~ age + gender + race + education + region + income +
religion + church + marital + work_status + religion_important,
data = train_demo_80, ntree = 500)
rf_demo_prob_80 <- predict(rf_demo_80, test_demo_80, type = "prob")[, "Republican"]
rf_demo_pred_80 <- predict(rf_demo_80, test_demo_80)
# Confusion matrices
cat(" CONFUSION MATRICES (1980s) \n\n")
print_cm_short <- function(label, pred, actual) {
cm <- confusionMatrix(pred, actual, positive = "Republican")
cat(label, "\n")
print(cm$table)
cat("Accuracy:", round(cm$overall["Accuracy"], 4),
"| 95% CI: (", round(cm$overall["AccuracyLower"], 4),
",", round(cm$overall["AccuracyUpper"], 4), ")\n")
cat("No Information Rate:", round(cm$overall["AccuracyNull"], 4),
"| P-Value [Acc > NIR]:", format.pval(cm$overall["AccuracyPValue"]), "\n\n")
}
print_cm_short("Attitudes: Logistic Regression", log_att_pred_80, test_att_80$party)
print_cm_short("Attitudes: Random Forest", rf_att_pred_80, test_att_80$party)
print_cm_short("Demographics: Logistic Regression", log_demo_pred_80, test_demo_80$party)
print_cm_short("Demographics: Random Forest", rf_demo_pred_80, test_demo_80$party)
# ROC CURVES + CONFUSION MATRIX: 2020s
library(pROC)
# Attitudes models (2020s)
subset_raw_20 <- data_ml %>%
filter(decade == "2020s") %>%
select(party, all_of(attitude_vars_clean)) %>%
filter(!is.na(party))
data_imp_20 <- complete(mice(subset_raw_20, m = 1, maxit = 10,
method = "pmm", seed = 123, printFlag = FALSE), 1)
set.seed(123)
idx_20       <- createDataPartition(data_imp_20$party, p = 0.7, list = FALSE)
train_att_20 <- data_imp_20[idx_20, ]
test_att_20  <- data_imp_20[-idx_20, ]
# Demographics models (2020s)
subset_demo_20 <- data_demo %>% filter(decade == "2020s")
set.seed(123)
idx2_20      <- createDataPartition(subset_demo_20$party, p = 0.7, list = FALSE)
train_demo_20 <- subset_demo_20[idx2_20, ]
test_demo_20  <- subset_demo_20[-idx2_20, ]
# LogReg attitudes
log_att_20      <- glm(party ~ ., data = train_att_20, family = binomial)
log_att_prob_20 <- predict(log_att_20, test_att_20, type = "response")
log_att_pred_20 <- factor(ifelse(log_att_prob_20 > 0.5, "Republican", "Democrat"),
levels = levels(test_att_20$party))
# RF attitudes
rf_att_20      <- randomForest(party ~ ., data = train_att_20, ntree = 500, mtry = 2)
rf_att_prob_20 <- predict(rf_att_20, test_att_20, type = "prob")[, "Republican"]
rf_att_pred_20 <- predict(rf_att_20, test_att_20)
# LogReg demographics
log_demo_20      <- glm(party ~ age + gender + race + education + region + income +
religion + church + marital + work_status + religion_important,
data = train_demo_20, family = binomial)
log_demo_prob_20 <- predict(log_demo_20, test_demo_20, type = "response")
log_demo_pred_20 <- factor(ifelse(log_demo_prob_20 > 0.5, "Republican", "Democrat"),
levels = levels(test_demo_20$party))
# RF demographics
rf_demo_20      <- randomForest(party ~ age + gender + race + education + region + income +
religion + church + marital + work_status + religion_important,
data = train_demo_20, ntree = 500)
rf_demo_prob_20 <- predict(rf_demo_20, test_demo_20, type = "prob")[, "Republican"]
rf_demo_pred_20 <- predict(rf_demo_20, test_demo_20)
# Confusion matrices
cat(" CONFUSION MATRICES (2020s) \n\n")
print_cm_short <- function(label, pred, actual) {
cm <- confusionMatrix(pred, actual, positive = "Republican")
cat(label, "\n")
print(cm$table)
cat("Accuracy:", round(cm$overall["Accuracy"], 4),
"| 95% CI: (", round(cm$overall["AccuracyLower"], 4),
",", round(cm$overall["AccuracyUpper"], 4), ")\n")
cat("No Information Rate:", round(cm$overall["AccuracyNull"], 4),
"| P-Value [Acc > NIR]:", format.pval(cm$overall["AccuracyPValue"]), "\n\n")
}
print_cm_short("Attitudes: Logistic Regression", log_att_pred_20, test_att_20$party)
print_cm_short("Attitudes: Random Forest", rf_att_pred_20, test_att_20$party)
print_cm_short("Demographics: Logistic Regression", log_demo_pred_20, test_demo_20$party)
print_cm_short("Demographics: Random Forest", rf_demo_pred_20, test_demo_20$party)
