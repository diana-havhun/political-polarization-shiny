library(pROC)
# Attitudes models (2020s)
subset_raw <- data_ml %>%
filter(decade == "2020s") %>%
select(party, all_of(attitude_vars_clean)) %>%
filter(!is.na(party))
data_imp <- complete(mice(subset_raw, m = 1, maxit = 10,
method = "pmm", seed = 123, printFlag = FALSE), 1)
set.seed(123)
idx <- createDataPartition(data_imp$party, p = 0.7, list = FALSE)
train_att_20 <- data_imp[idx, ]
test_att_20  <- data_imp[-idx, ]
# LogReg attitudes
log_att_20 <- glm(party ~ ., data = train_att_20, family = binomial)
log_att_prob_20 <- predict(log_att, test_att_20, type = "response")
log_att_pred_20 <- factor(ifelse(log_att_prob_20 > 0.5, "Republican", "Democrat"),
levels = levels(test_att_20$party))
# RF attitudes
rf_att_20 <- randomForest(party ~ ., data = train_att, ntree = 500, mtry = 2)
rf_att_prob_20 <- predict(rf_att, test_att_20, type = "prob")[, "Republican"]
rf_att_pred_20 <- predict(rf_att, test_att_20)
cat(" CONFUSION MATRICES (2020s) \n\n")
cat(" Attitudes: Logistic Regression \n")
print(confusionMatrix(log_att_pred, test_att$party, positive = "Republican"))
cat("\n Attitudes: Random Forest \n")
print(confusionMatrix(rf_att_pred, test_att$party, positive = "Republican"))
# ROC CURVES: 2020s
roc_log_att <- roc(as.numeric(test_att_20$party == "Republican"), log_att_prob_20, quiet = TRUE)
roc_rf_att  <- roc(as.numeric(test_att_20$party == "Republican"), rf_att_prob_20,  quiet = TRUE)
roc_log_demo <- roc(as.numeric(test_demo_20$party == "Republican"), log_demo_prob_20, quiet = TRUE)
# ROC CURVES + CONFUSION MATRIX: 2020s
library(pROC)
# Attitudes models (2020s)
subset_raw_20 <- data_ml %>%
filter(decade == "2020s") %>%
select(party, all_of(attitude_vars_clean)) %>%
filter(!is.na(party))
data_imp_20 <- complete(mice(subset_raw_20, m = 1, maxit = 10,
method = "pmm", seed = 123, printFlag = FALSE), 1)
set.seed(123)
idx_20       <- createDataPartition(data_imp_20$party, p = 0.7, list = FALSE)
train_att_20 <- data_imp_20[idx_20, ]
test_att_20  <- data_imp_20[-idx_20, ]
# Demographics models (2020s)
subset_demo_20 <- data_demo %>% filter(decade == "2020s")
set.seed(123)
idx2_20      <- createDataPartition(subset_demo_20$party, p = 0.7, list = FALSE)
train_demo_20 <- subset_demo_20[idx2_20, ]
test_demo_20  <- subset_demo_20[-idx2_20, ]
# LogReg attitudes
log_att_20      <- glm(party ~ ., data = train_att_20, family = binomial)
log_att_prob_20 <- predict(log_att_20, test_att_20, type = "response")
log_att_pred_20 <- factor(ifelse(log_att_prob_20 > 0.5, "Republican", "Democrat"),
levels = levels(test_att_20$party))
# RF attitudes
rf_att_20      <- randomForest(party ~ ., data = train_att_20, ntree = 500, mtry = 2)
rf_att_prob_20 <- predict(rf_att_20, test_att_20, type = "prob")[, "Republican"]
rf_att_pred_20 <- predict(rf_att_20, test_att_20)
# LogReg demographics
log_demo_20      <- glm(party ~ age + gender + race + education + region + income +
religion + church + marital + work_status + religion_important,
data = train_demo_20, family = binomial)
log_demo_prob_20 <- predict(log_demo_20, test_demo_20, type = "response")
log_demo_pred_20 <- factor(ifelse(log_demo_prob_20 > 0.5, "Republican", "Democrat"),
levels = levels(test_demo_20$party))
# RF demographics
rf_demo_20      <- randomForest(party ~ age + gender + race + education + region + income +
religion + church + marital + work_status + religion_important,
data = train_demo_20, ntree = 500)
rf_demo_prob_20 <- predict(rf_demo_20, test_demo_20, type = "prob")[, "Republican"]
rf_demo_pred_20 <- predict(rf_demo_20, test_demo_20)
# Confusion matrices
cat(" CONFUSION MATRICES (2020s) \n\n")
cat(" Attitudes: Logistic Regression \n")
print(confusionMatrix(log_att_pred_20, test_att_20$party, positive = "Republican"))
cat("\n Attitudes: Random Forest \n")
print(confusionMatrix(rf_att_pred_20, test_att_20$party, positive = "Republican"))
cat("\n Demographics: Logistic Regression \n")
print(confusionMatrix(log_demo_pred_20, test_demo_20$party, positive = "Republican"))
cat("\n Demographics: Random Forest \n")
print(confusionMatrix(rf_demo_pred_20, test_demo_20$party, positive = "Republican"))
# ROC CURVES: 2020s
roc_log_att  <- roc(as.numeric(test_att_20$party  == "Republican"), log_att_prob_20,  quiet = TRUE)
roc_rf_att   <- roc(as.numeric(test_att_20$party  == "Republican"), rf_att_prob_20,   quiet = TRUE)
roc_log_demo <- roc(as.numeric(test_demo_20$party == "Republican"), log_demo_prob_20, quiet = TRUE)
roc_rf_demo  <- roc(as.numeric(test_demo_20$party == "Republican"), rf_demo_prob_20,  quiet = TRUE)
plot(roc_log_att, col = "#7b68ee", lwd = 2,
main = "ROC Curves — 2020s Models")
lines(roc_rf_att,   col = "#2d8659", lwd = 2)
lines(roc_log_demo, col = "#e6994a", lwd = 2)
lines(roc_rf_demo,  col = "#c9853a", lwd = 2, lty = 2)
abline(a = 0, b = 1, lty = 3, col = "gray50")
legend("bottomright",
legend = c(paste0("Attitudes LogReg (AUC=", round(auc(roc_log_att),  3), ")"),
paste0("Attitudes RF     (AUC=", round(auc(roc_rf_att),   3), ")"),
paste0("Demographics LogReg (AUC=", round(auc(roc_log_demo), 3), ")"),
paste0("Demographics RF  (AUC=", round(auc(roc_rf_demo),  3), ")")),
col = c("#7b68ee", "#2d8659", "#e6994a", "#c9853a"),
lwd = 2, lty = c(1, 1, 1, 2), cex = 0.9)
