The ideological divergence chart provides descriptive support for increasing polarization. In the 1970s, average self-placement was roughly "Moderate" for Democrats and "Slightly Conservative" for Republicans — a small gap consistent with @fiorina2005's characterization of a moderate public. By the 2020s, both parties have moved toward their respective poles, with Democrats averaging "Slightly Liberal" and Republicans approaching "Conservative." This divergence is consistent with @abramowitz2008's argument that partisan sorting is real and measurable. Importantly, however, this chart reflects self-placement on a single dimension; the machine learning models below use issue-specific attitudes to assess *actual* sorting behavior, not just self-identification.



```{r}
library(caret)

demographic_vars <- c("age", "gender", "race", "education", "region", 
                      "income", "religion", "church")

attitude_vars <- c("gov_health_insurance", "gov_jobs", "aid_black",
                   "abortion", "gov_spending", "env_regulation", 
                   "defense_spending", "affirmative_action",
                   "protect_homosexuals", "gay_adoption", "death_penalty",
                   "immigration", "religion_important", "bible_authority",
                   "moral_adjust", "traditional_values",
                   "black_conditions", "black_no_favors", 
                   "black_try_harder", "black_gotten_less",
                   "equal_opportunity", "not_problem_unequal",
                   "worry_less_equality", "fewer_problems_equal")

all_vars <- c(demographic_vars, attitude_vars)

decades <- c("1980s", "1990s", "2000s", "2010s", "2020s")

set.seed(123)
results <- data.frame()

for (dec in decades) {
  
  subset_full <- data_model %>% filter(decade == dec)
  
  for (model_type in c("Demographics", "Attitudes")) {
    
    candidate_vars <- switch(model_type,
      "Demographics" = demographic_vars,
      "Attitudes" = attitude_vars
    )
    
    available <- candidate_vars[sapply(candidate_vars, function(v) {
      mean(!is.na(subset_full[[v]])) > 0.3
    })]
    
    if (length(available) < 3) next
    
    subset <- subset_full %>%
      select(party, all_of(available)) %>%
      drop_na()
    
    if (nrow(subset) < 100) next
    
    train_idx <- createDataPartition(subset$party, p = 0.7, list = FALSE)
    train <- subset[train_idx, ]
    test <- subset[-train_idx, ]
    
    model <- glm(party ~ ., data = train, family = binomial)
    
    pred_prob <- predict(model, newdata = test, type = "response")
    pred_class <- ifelse(pred_prob > 0.5, "Republican", "Democrat")
    accuracy <- mean(pred_class == test$party)
    
    results <- rbind(results, data.frame(
      decade = dec,
      model_type = model_type,
      accuracy = round(accuracy * 100, 1),
      n_train = nrow(train),
      n_test = nrow(test),
      n_predictors = length(available),
      predictors_used = paste(available, collapse = ", ")
    ))
  }
}

head(results %>% select(-predictors_used), 20)

results %>% 
  filter(model_type == "Attitudes") %>%
  select(decade, n_predictors, predictors_used) %>%
  print(width = 200)
```

